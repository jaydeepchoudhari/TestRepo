import { Injectable } from '@angular/core';
import { HttpClient, HttpHeaders } from '@angular/common/http';
import { Observable } from 'rxjs';

@Injectable({
  providedIn: 'root'
})
export class VaultService {

  private vaultUrl = 'https://your-vault-server/v1/auth/ldap/login';  // Vault LDAP auth URL
  private username = 'your-ldap-username';  // LDAP username
  private password = 'your-ldap-password';  // LDAP password (should be securely handled)
  
  constructor(private http: HttpClient) { }

  // Function to authenticate via LDAP and get the Vault token
  authenticateViaLDAP(): Observable<any> {
    const credentials = {
      "password": this.password
    };

    return this.http.post(this.vaultUrl + `/${this.username}`, credentials);
  }

  // Function to retrieve secret after getting the Vault token
  getSecret(vaultToken: string): Observable<any> {
    const headers = new HttpHeaders({
      'X-Vault-Token': vaultToken
    });

    const secretUrl = 'https://your-vault-server/v1/secret/data/my-secret';
    return this.http.get(secretUrl, { headers });
  }
}
