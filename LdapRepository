using Microsoft.Data.SqlClient;
using OfficeOpenXml;
using System.Data;

namespace SqlToExcel
{
    public class Template
    {
        public int Id { get; set; }
        public string Name { get; set; }
    }
    internal class Program
    {
        private const string ConnectionString =
    "Server=YOUR_SERVER;Database=YOUR_DATABASE;" +
    "User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;";

        private const string StoredProcedureName = "dbo.Addsections";

        static void Main(string[] args)
        {

            List<Template> list = new List<Template>();

            list.Add(new Template { Id = 1, Name = "Name" });


            foreach (Template template in list)
            {

                DataTable dt = ExecuteStoredProcedure(
                        connectionString: ConnectionString,
                        storedProcedure: StoredProcedureName,
                        parameters: BuildParameters(template.Id)   // add/remove SP params here
                    );

                using (var package = new ExcelPackage())
                {
                    var sheet = package.Workbook.Worksheets.Add(template.Name);

                    sheet.Cells["A1"].LoadFromDataTable(dt, false);

                    sheet.Cells[sheet.Dimension.Address].AutoFitColumns();

                    var fileInfo = new FileInfo(@"C:\Temp\DataTableExport.xlsx");
                    package.SaveAs(fileInfo);
                }
            }
        }

        private static DataTable ExecuteStoredProcedure(
            string connectionString,
            string storedProcedure,
            SqlParameter[] parameters)
        {
            var dt = new DataTable();

            using (var conn = new SqlConnection(connectionString))
            using (var cmd = new SqlCommand(storedProcedure, conn))
            {
                cmd.CommandType = CommandType.StoredProcedure;
                cmd.CommandTimeout = 1200; // seconds — increase for long-running SPs

                if (parameters != null)
                    cmd.Parameters.AddRange(parameters);

                conn.Open();

                using (var adapter = new SqlDataAdapter(cmd))
                    adapter.Fill(dt);
            }

            return dt;
        }

        private static SqlParameter[] BuildParameters(int id)
        {
            return new[]
            {
        new SqlParameter("@TemplateId", SqlDbType.Int) { Value = id },
        new SqlParameter("@IsCnt",   SqlDbType.Bit) { Value = true },
    };
        }
    }
}
