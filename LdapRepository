name: Formula Web Build and Deploy

on:
  workflow_dispatch:
    inputs:
      environment:
        description: "Environment to deploy to"
        type: choice
        required: true
        options: [dev, qa, prod]
      operation:
        description: "Operation to perform"
        type: choice
        required: true
        default: "deploy"
        options: [build, deploy, rollback, undeploy]
      rollback_commit:
        description: "Commit SHA to rollback to (only for rollback operation)"
        type: string
        required: false

jobs:
  instamod:
    permissions:
      actions: read
      contents: read
      id-token: write
      security-events: write
    uses: dukeenergy-corp/duke-actions/.github/workflows/reusable-instamod.yaml@master
    with:
      application_name: formula-web
      values-files:  ci/manifests/values.yaml
      dockerfile-path: ci/Dockerfile
      environment: ${{ github.event_name == 'workflow_dispatch' && inputs.environment || '' }}
      operation: ${{ github.event_name == 'workflow_dispatch' && inputs.operation || 'deploy' }}
      rollback_commit: ${{ inputs.rollback_commit || '' }}
